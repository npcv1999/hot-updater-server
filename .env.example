PORT=3001
DATABASE_URL="postgresql://postgres:your-password@localhost:5432/hot_updater?schema=public"
HOT_UPDATER_AUTH_TOKEN="change-me"
HOT_UPDATER_SERVER_URL="http://localhost:3001/hot-updater"
# true: nếu user bỏ lỡ một bản force thì bản update mới nhất cũng trả về force
STICKY_FORCE_UPDATE=false

S3_REGION="ap-southeast-2"
S3_ENDPOINT=
S3_ACCESS_KEY_ID="your-access-key"
S3_SECRET_ACCESS_KEY="your-secret-key"
S3_BUCKET_NAME="your-bucket-name"

POSTGRES_DB="hot_updater"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="your-password"
