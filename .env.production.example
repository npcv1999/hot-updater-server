STICKY_FORCE_UPDATE=false

S3_REGION="us-east-1"
S3_ENDPOINT=
S3_ACCESS_KEY_ID="AKIA..."
S3_SECRET_ACCESS_KEY="..."
S3_BUCKET_NAME="your-bucket-name"

POSTGRES_DB="hot_updater"
