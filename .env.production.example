PORT=3001
DATABASE_URL="postgresql://postgres:CHANGE_ME_STRONG_PASSWORD@postgres:5432/hot_updater?schema=public"
HOT_UPDATER_AUTH_TOKEN="CHANGE_ME_LONG_RANDOM_TOKEN"
