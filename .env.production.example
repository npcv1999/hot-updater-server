PORT=3001
# Host is the compose service name "postgres" (not localhost); user/password/db must match POSTGRES_* below
DATABASE_URL="postgresql://postgres:change-me@postgres:5432/hot_updater?schema=public"
HOT_UPDATER_AUTH_TOKEN="generate-with: openssl rand -hex 32"
HOT_UPDATER_SERVER_URL="https://updates.example.com/hot-updater"
# true: nếu user bỏ lỡ một bản force thì bản update mới nhất cũng trả về force
STICKY_FORCE_UPDATE=false

S3_REGION="ap-southeast-2"
S3_ENDPOINT=
S3_ACCESS_KEY_ID="your-access-key"
S3_SECRET_ACCESS_KEY="your-secret-key"
S3_BUCKET_NAME="your-bucket-name"

POSTGRES_DB="hot_updater"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="change-me"
