{
  "name": "hot-updater-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "build": "tsc",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "hot-updater:schema": "hot-updater db generate src/hotUpdater.ts --yes"
  },
  "dependencies": {
    "@hot-updater/aws": "^0.35.3",
    "@hot-updater/server": "^0.35.3",
    "@prisma/client": "^6.11.1",
    "dotenv": "^17.0.1",
    "express": "^5.1.0",
    "prisma": "^6.11.1",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@hot-updater/bare": "^0.35.3",
    "@hot-updater/core": "^0.35.3",
    "@hot-updater/standalone": "^0.35.3",
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.10",
    "@types/swagger-ui-express": "^4.1.8",
    "hot-updater": "^0.35.3",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
