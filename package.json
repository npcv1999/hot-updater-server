{
  "name": "hot-updater-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev -w hot-updater-api",
    "dev:api": "npm run dev -w hot-updater-api",
    "dev:web": "npm run dev -w hot-updater-dashboard",
    "start": "npm run start -w hot-updater-api",
    "build": "npm run build -w hot-updater-api",
    "build:api": "npm run build -w hot-updater-api",
    "build:web": "npm run build -w hot-updater-dashboard",
    "prisma:generate": "npm run prisma:generate -w hot-updater-api",
    "prisma:migrate": "npm run prisma:migrate -w hot-updater-api",
    "prisma:migrate:deploy": "npm run prisma:migrate:deploy -w hot-updater-api",
    "hot-updater:schema": "npm run hot-updater:schema -w hot-updater-api"
  }
}
